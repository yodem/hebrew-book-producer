{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh",
            "statusMessage": "Loading hebrew-book-producer references..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/voice-pull.sh",
            "statusMessage": "Syncing voice profile from CandleKeep..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/voice/voice-migrate.sh",
            "statusMessage": "Running voice profile migration (idempotent)..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-edit-snapshot.sh",
            "statusMessage": "Snapshotting file before edit..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-feedback.sh",
            "statusMessage": "Logging diff to .book-producer/memory.md..."
          }
        ]
      }
    ]
  }
}
